{
  "name": "bigquery-orm",
  "version": "1.0.5",
  "description": "An ORM for Google BigQuery with TypeScript decorators and query builders",
  "author": "Eric Pereira <eric_pereira95@hotmail.com>",
  "license": "MIT",
  "keywords": [
    "bigquery",
    "orm",
    "google-cloud",
    "database",
    "google-bigquery",
    "typescript",
    "query-builder"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write lib/**/*.ts",
    "lint": "eslint lib --ext ts,tsx",
    "lint:fix": "eslint lib --ext ts,tsx --fix",
    "build": "tsc --declaration",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20.11.1"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@google-cloud/bigquery": "^7.9.1",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "eslint": "^8.2.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "bugs": {
    "url": "https://github.com/cirebox/bigqueryorm/issues"
  },
  "homepage": "https://github.com/cirebox/bigqueryorm#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cirebox/bigqueryorm.git"
  }
}